{
  "name": "oet-study-partner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "import-pdfs": "python3 scripts/import-pdfs.py",
    "import-audio": "python3 scripts/import-audio.py",
    "generate:question-audio": "node scripts/generate-question-audio.mjs",
    "test:audio-relevance": "node scripts/validate-question-audio.mjs",
    "test:audio-spoken": "node scripts/audit-question-audio.mjs",
    "import-ashgan-telegram": "python3 scripts/import-ashgan-telegram.py",
    "import-ashgan": "python3 scripts/import-ashgan-assets.py",
    "import-ashgan:public": "python3 scripts/import-ashgan-assets.py --default-handles --download --write-ts --limit 12",
    "import-ashgan:test-export": "python3 scripts/import-ashgan-assets.py --test-export-fixture",
    "verify-no-duplicates": "npx tsx scripts/verify-no-duplicates.ts"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
